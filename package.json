{
  "displayName": "Homebridge LG ThinQ",
  "name": "homebridge-lg-thinq",
  "version": "2.0.0",
  "description": "A Homebridge plugin for controlling/monitoring LG ThinQ devices via LG ThinQ platform.",
  "license": "Apache-2.0",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/nVuln/homebridge-lg-thinq.git"
  },
  "bugs": {
    "url": "https://github.com/nVuln/homebridge-lg-thinq/issues"
  },
  "engines": {
    "homebridge": "^1.11.2 || ^2.0.0",
    "node": "^22.13.0 || ^24.0.0"
  },
  "main": "dist/index.js",
  "bin": {
    "thinq": "./dist/cli.js"
  },
  "scripts": {
    "build": "rimraf ./dist && tsc",
    "lint": "eslint . --max-warnings=0",
    "check": "npm run lint && npm run build && npm run test:coverage",
    "prepublishOnly": "npm run lint && npm run build",
    "watch": "npm run build && npm link && nodemon",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "test:coverage": "rimraf ./coverage && jest --coverage --runInBand"
  },
  "keywords": [
    "homebridge-plugin",
    "homekit",
    "lg",
    "lg-thinq"
  ],
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@jest/globals": "^30.3.0",
    "@types/aws-iot-device-sdk": "^2.2.9",
    "@types/luxon": "^3.7.1",
    "@types/node": "^25.6.0",
    "@types/node-forge": "^1.3.14",
    "@types/node-persist": "^3.1.8",
    "@types/qs": "^6.15.0",
    "eslint": "^10.3.0",
    "homebridge": "^2.0.0",
    "jest": "^30.3.0",
    "nodemon": "^3.1.14",
    "rimraf": "^6.1.3",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1"
  },
  "homepage": "https://github.com/nVuln/homebridge-lg-thinq#readme",
  "author": "nVuln",
  "dependencies": {
    "@homebridge/plugin-ui-utils": "^2.2.3",
    "aws-iot-device-sdk": "^2.2.16",
    "axios": "^1.16.0",
    "axios-retry": "^4.5.0",
    "commander": "^14.0.3",
    "luxon": "^3.7.2",
    "node-forge": "^1.4.0",
    "node-persist": "^4.0.4",
    "qs": "^6.15.1"
  },
  "overrides": {
    "glob": "^13.0.6",
    "help-me": {
      "glob": "^13.0.6"
    },
    "node-persist": "^4.0.4"
  }
}
